# Copy to .env (or set these in your hosting provider's dashboard). Nothing in the source
# code hardcodes a host, port, or URL — everything below has a sane default if unset.

# What address/port the server listens on. Most hosts (Render, Railway, Fly.io, etc.) inject
# PORT automatically; HOST should stay 0.0.0.0 so the app is reachable from outside the
# container.
PORT=3000
HOST=0.0.0.0

# Allowed origin for the API during local development if the frontend runs on a different
# port than the backend. "*" is fine for this project (no auth/cookies involved).
CORS_ORIGIN=*

# Cover art pipeline. "auto" tries AI art -> stock photo -> procedural fallback, in that
# order. Force a single tier with "ai" | "stock" | "procedural" (useful for fully offline
# development/testing).
COVER_MODE=auto
AI_IMAGE_BASE_URL=https://image.pollinations.ai/prompt
AI_IMAGE_MODEL=flux
AI_IMAGE_TIMEOUT_MS=15000
STOCK_IMAGE_BASE_URL=https://picsum.photos/seed
STOCK_IMAGE_TIMEOUT_MS=8000
